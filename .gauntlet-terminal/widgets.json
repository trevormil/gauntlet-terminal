[
  {
    "id": "uncommitted",
    "title": "Uncommitted",
    "icon": "📝",
    "command": "git status --porcelain | wc -l | tr -d ' '",
    "intervalMs": 4000,
    "mode": "big"
  },
  {
    "id": "branch-status",
    "title": "Git",
    "icon": "⎇",
    "command": "git status -sb | head -6",
    "intervalMs": 5000,
    "mode": "text"
  },
  {
    "id": "last-commit",
    "title": "Last Commit",
    "icon": "⏱",
    "command": "git log -1 --format='%h  %s' | cut -c1-44",
    "intervalMs": 8000,
    "mode": "text"
  }
]
