#!/usr/bin/env bun
// terminal-mcp-server — Model Context Protocol server exposing TerMinal's
// cross-session state to in-session Claude/Codex agents.
//
// READ tools: cross-session views (tickets, PRs, schedules, runs, spend).
// WRITE tools: deterministic data filing (ticket, hitl, activity, state)
// so agents skip reading ~5-7k tokens of skill files every time they file
// data. Schema decisions stay with the model; schema formatting is done here.

import { readFileSync, readdirSync, existsSync, statSync, writeFileSync, mkdirSync, appendFileSync } from 'node:fs'
import { join, basename, dirname, sep } from 'node:path'
import { randomUUID } from 'node:crypto'
import { homedir } from 'node:os'

const CFG = join(homedir(), '.config', 'TerMinal')
const PRS_ROOT = join(homedir(), 'CompSci', 'gauntlet', 'autopilot-harness', 'prs')

// ---------------------------------------------------------------------------
// Frontmatter parser (mirrors the renderer-side parser; minimal, regex-only)
// ---------------------------------------------------------------------------
function parseFrontmatter(md) {
  const m = md.match(/^---\r?\n([\s\S]*?)\r?\n---\r?\n?([\s\S]*)$/)
  if (!m) return { meta: {}, body: md }
  const meta = {}
  for (const line of m[1].split(/\r?\n/)) {
    const lm = line.match(/^([A-Za-z_][\w-]*):\s*(.*)$/)
    if (!lm) continue
    const raw = lm[2].trim()
    if (!raw) continue
    let val = raw
    if (raw === 'true' || raw === 'false') val = raw === 'true'
    else if (/^-?\d+(\.\d+)?$/.test(raw)) val = Number(raw)
    else if (raw.startsWith('"') && raw.endsWith('"')) val = raw.slice(1, -1)
    else if (raw.startsWith('[') && raw.endsWith(']')) {
      val = raw
        .slice(1, -1)
        .split(',')
        .map((s) => s.trim().replace(/^["']|["']$/g, ''))
        .filter(Boolean)
    }
    meta[lm[1]] = val
  }
  return { meta, body: m[2] || '' }
}

// ---------------------------------------------------------------------------
// Resource readers — each delegates to existing on-disk shapes
// ---------------------------------------------------------------------------

function knownRepoRoots() {
  // Repos known to the harness: anything with a schedule, anything in
  // prs/cache.json, anything in the workspaces persisted state, anything in
  // bg-tasks.json.
  const roots = new Set()
  // schedules.json
  try {
    const sf = join(CFG, 'schedules.json')
    if (existsSync(sf)) {
      const arr = JSON.parse(readFileSync(sf, 'utf8'))
      for (const s of arr) if (s.repoRoot) roots.add(s.repoRoot)
    }
  } catch {}
  // bg-tasks.json
  try {
    const bf = join(CFG, 'bg-tasks.json')
    if (existsSync(bf)) {
      const arr = JSON.parse(readFileSync(bf, 'utf8'))
      for (const t of arr) if (t.repoRoot) roots.add(t.repoRoot)
    }
  } catch {}
  // Walk common parent dir to find any repo not yet known
  const parent = join(homedir(), 'CompSci', 'gauntlet')
  if (existsSync(parent)) {
    try {
      for (const name of readdirSync(parent)) {
        const p = join(parent, name)
        if (name.startsWith('.')) continue
        if (existsSync(join(p, '.git'))) roots.add(p)
      }
    } catch {}
  }
  return [...roots]
}

function findRepoRoot(repoArg) {
  if (!repoArg) return null
  const target = repoArg.toLowerCase()
  for (const root of knownRepoRoots()) {
    const b = basename(root).toLowerCase()
    if (b === target || root.toLowerCase().endsWith(target)) return root
  }
  return null
}

// --- tickets ---------------------------------------------------------------

function listTicketsForRoot(repoRoot, filter) {
  const dir = join(repoRoot, 'backlog')
  if (!existsSync(dir)) return []
  const out = []
  let files
  try {
    files = readdirSync(dir)
  } catch {
    return []
  }
  for (const f of files) {
    if (!/^\d{4}-.*\.md$/.test(f)) continue
    let raw
    try {
      raw = readFileSync(join(dir, f), 'utf8')
    } catch {
      continue
    }
    const { meta, body } = parseFrontmatter(raw)
    const slug = f.replace(/\.md$/, '')
    const ticket = {
      slug,
      id: typeof meta.id === 'number' ? meta.id : parseInt(slug.slice(0, 4), 10),
      title: meta.title || slug,
      status: meta.status || 'open',
      priority: meta.priority || 'medium',
      type: meta.type || 'feature',
      horizon: meta.horizon || 'now',
      hitl: meta.hitl === true,
      created: meta.created,
      updated: meta.updated,
      prs: meta.prs || [],
      repo: basename(repoRoot),
      body: body.slice(0, 600), // truncate; agents can fetch full via get_ticket
    }
    if (filter?.status && ticket.status !== filter.status) continue
    if (filter?.type && ticket.type !== filter.type) continue
    out.push(ticket)
  }
  return out.sort((a, b) => a.id - b.id)
}

function listTicketsTool(args) {
  const repo = args.repo
  const roots = repo ? [findRepoRoot(repo)].filter(Boolean) : knownRepoRoots()
  const filter = { status: args.status, type: args.type }
  return roots.flatMap((r) => listTicketsForRoot(r, filter))
}

function getTicketTool(args) {
  const slug = args.slug
  if (!slug) return null
  // Try every known repo until we find it
  for (const root of knownRepoRoots()) {
    const f = join(root, 'backlog', `${slug}.md`)
    if (existsSync(f)) {
      const raw = readFileSync(f, 'utf8')
      const { meta, body } = parseFrontmatter(raw)
      return {
        slug,
        repo: basename(root),
        repoRoot: root,
        ...meta,
        body,
      }
    }
  }
  return null
}

// --- PRs / MRs (from autopilot-harness's prs/ artifact store) -------------

function listPrs(args) {
  if (!existsSync(PRS_ROOT)) return []
  const out = []
  // prs/<host>/<owner>/<name>/<num>/meta.json
  const walk = (dir, depth = 0) => {
    if (depth > 4) return
    let names
    try {
      names = readdirSync(dir)
    } catch {
      return
    }
    for (const name of names) {
      const p = join(dir, name)
      let st
      try {
        st = statSync(p)
      } catch {
        continue
      }
      if (st.isDirectory()) walk(p, depth + 1)
      else if (name === 'meta.json') {
        try {
          const meta = JSON.parse(readFileSync(p, 'utf8'))
          if (args.repo && !meta.repo?.toLowerCase().includes(args.repo.toLowerCase())) continue
          if (args.status && meta.state !== args.status) continue
          out.push({
            host: meta.host,
            repo: meta.repo,
            number: meta.number,
            title: meta.title,
            state: meta.state,
            webUrl: meta.webUrl,
            author: meta.author,
            updatedAt: meta.updatedAt,
            commits: (meta.commits || []).length,
          })
        } catch {}
      }
    }
  }
  walk(PRS_ROOT)
  return out.sort((a, b) => String(b.updatedAt).localeCompare(String(a.updatedAt))).slice(0, 50)
}

function getPrArtifact(args) {
  const { host, repo, number, sha } = args
  if (!host || !repo || !number) return null
  const dir = join(PRS_ROOT, host, ...repo.split('/'), String(number))
  if (!existsSync(dir)) return null
  // Default sha = first commit in meta.json (newest)
  let targetSha = sha
  if (!targetSha) {
    try {
      const meta = JSON.parse(readFileSync(join(dir, 'meta.json'), 'utf8'))
      targetSha = meta.commits?.[0]?.slice(0, 7)
    } catch {}
  }
  if (!targetSha) return null
  const file = join(dir, `${targetSha}.md`)
  if (!existsSync(file)) return null
  const raw = readFileSync(file, 'utf8')
  const { meta, body } = parseFrontmatter(raw)
  return { host, repo, number, sha: targetSha, meta, body }
}

// --- schedules + agent runs -----------------------------------------------

function listSchedules(args) {
  const sf = join(CFG, 'schedules.json')
  if (!existsSync(sf)) return []
  try {
    const arr = JSON.parse(readFileSync(sf, 'utf8'))
    return arr.filter((s) => !args.repo || s.repoLabel?.toLowerCase().includes(args.repo.toLowerCase()))
  } catch {
    return []
  }
}

function recentAgentRuns(args) {
  const out = []
  // cron-runs/
  const cronDir = join(CFG, 'cron-runs')
  if (existsSync(cronDir)) {
    try {
      for (const f of readdirSync(cronDir)) {
        if (!f.endsWith('.json')) continue
        try {
          const r = JSON.parse(readFileSync(join(cronDir, f), 'utf8'))
          if (args.repo && !r.repoLabel?.toLowerCase().includes(args.repo.toLowerCase())) continue
          if (args.status && r.status !== args.status) continue
          out.push({ ...r, source: 'cron' })
        } catch {}
      }
    } catch {}
  }
  return out.sort((a, b) => (b.startedAt || 0) - (a.startedAt || 0)).slice(0, args.limit || 50)
}

function aiSpendToday(args) {
  // Read ai-runs/ and roll up for today
  const dir = join(CFG, 'ai-runs')
  if (!existsSync(dir)) return { totalUsd: 0, totalRuns: 0, byModel: {}, byAgent: {} }
  const dayStart = (() => {
    const d = new Date()
    d.setHours(0, 0, 0, 0)
    return d.getTime()
  })()
  let totalUsd = 0
  let totalRuns = 0
  const byModel = {}
  const byAgent = {}
  try {
    for (const f of readdirSync(dir)) {
      if (!f.endsWith('.json')) continue
      try {
        const r = JSON.parse(readFileSync(join(dir, f), 'utf8'))
        if ((r.startedAt || 0) < dayStart) continue
        if (args.repo) {
          const b = basename(r.repoRoot || '')
          if (!b.toLowerCase().includes(args.repo.toLowerCase())) continue
        }
        if (args.agent && r.agentId !== args.agent) continue
        totalUsd += r.costUsd || 0
        totalRuns++
        byModel[r.model] = (byModel[r.model] || 0) + (r.costUsd || 0)
        if (r.agentId) byAgent[r.agentId] = (byAgent[r.agentId] || 0) + (r.costUsd || 0)
      } catch {}
    }
  } catch {}
  return { totalUsd, totalRuns, byModel, byAgent }
}

// ===========================================================================
// WRITE TOOLS — deterministic data filing. Agents skip reading SKILL.md.
// ===========================================================================

const todayStr = () => new Date().toISOString().slice(0, 10)
const slugify = (s) =>
  s
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '')
    .slice(0, 50) || 'untitled'

// --- file_ticket ----------------------------------------------------------

function fileTicket(args) {
  const { repo, title, body = '', type = 'feature', priority = 'medium', status = 'open', source = 'mcp' } = args
  if (!title) throw new Error('title is required')
  const repoRoot = findRepoRoot(repo)
  if (!repoRoot) throw new Error(`no repo matching "${repo}"`)
  const backlogDir = join(repoRoot, 'backlog')
  if (!existsSync(backlogDir)) throw new Error(`${repoRoot}/backlog/ does not exist`)
  // Atomic-ish ID allocation via .next-id (matches bin/next-backlog-id semantics)
  const nextIdFile = join(backlogDir, '.next-id')
  let nextId = 1
  if (existsSync(nextIdFile)) {
    try {
      nextId = parseInt(readFileSync(nextIdFile, 'utf8').trim(), 10) || 1
    } catch {}
  } else {
    // Fall back to highest existing + 1
    const files = readdirSync(backlogDir).filter((f) => /^\d{4}-.*\.md$/.test(f))
    nextId = files.reduce((m, f) => Math.max(m, parseInt(f.slice(0, 4), 10)), 0) + 1
  }
  const id = String(nextId).padStart(4, '0')
  const slug = `${id}-${slugify(title)}`
  const today = todayStr()
  const frontmatter = `---
id: ${nextId}
title: ${JSON.stringify(title)}
status: ${status}
priority: ${priority}
horizon: now
hitl: false
type: ${type}
source: ${source}
created: ${today}
updated: ${today}
prs: []
refs: []
depends_on: []
---

${body}
`
  const path = join(backlogDir, `${slug}.md`)
  writeFileSync(path, frontmatter)
  // Bump .next-id
  try {
    writeFileSync(nextIdFile, String(nextId + 1) + '\n')
  } catch {}
  // Emit activity event so the harness picks it up
  emitActivityRaw({ kind: 'ticket-filed', title: `Ticket filed · #${id}`, detail: title, repo: basename(repoRoot), repoRoot })
  return { slug, id, path }
}

// --- update_ticket --------------------------------------------------------

function updateTicket(args) {
  const { slug, status, priority, appendPrUrl, removePrUrl } = args
  if (!slug) throw new Error('slug is required')
  let path = null
  let repoRoot = null
  for (const root of knownRepoRoots()) {
    const p = join(root, 'backlog', `${slug}.md`)
    if (existsSync(p)) {
      path = p
      repoRoot = root
      break
    }
  }
  if (!path) throw new Error(`ticket ${slug} not found in any known repo`)
  let raw = readFileSync(path, 'utf8')
  const m = raw.match(/^(---\n[\s\S]*?\n---)([\s\S]*)$/)
  if (!m) throw new Error(`malformed frontmatter in ${path}`)
  let fm = m[1]
  const setField = (key, val) => {
    const re = new RegExp(`^(${key}:[ \\t]*).*$`, 'm')
    if (re.test(fm)) fm = fm.replace(re, `$1${val}`)
    else fm = fm.replace(/\n---$/, `\n${key}: ${val}\n---`)
  }
  if (status) setField('status', status)
  if (priority) setField('priority', priority)
  setField('updated', todayStr())
  // PR URL list manipulation — `prs:` is a YAML inline list
  if (appendPrUrl || removePrUrl) {
    const prsMatch = fm.match(/^prs:\s*(.*)$/m)
    let prs = []
    if (prsMatch) {
      const raw = prsMatch[1].trim()
      if (raw.startsWith('[') && raw.endsWith(']')) {
        prs = raw
          .slice(1, -1)
          .split(',')
          .map((s) => s.trim().replace(/^["']|["']$/g, ''))
          .filter(Boolean)
      }
    }
    if (appendPrUrl && !prs.includes(appendPrUrl)) prs.push(appendPrUrl)
    if (removePrUrl) prs = prs.filter((p) => p !== removePrUrl)
    const formatted = `[${prs.map((p) => JSON.stringify(p)).join(', ')}]`
    if (prsMatch) fm = fm.replace(/^prs:\s*.*$/m, `prs: ${formatted}`)
    else fm = fm.replace(/\n---$/, `\nprs: ${formatted}\n---`)
  }
  writeFileSync(path, fm + m[2])
  return { ok: true, path }
}

// --- file_hitl ------------------------------------------------------------

function fileHitlTool(args) {
  const { title, action, detail, repo, source = 'agent', runId, ticketPath } = args
  if (!title) throw new Error('title is required')
  const cfg = join(process.env.HOME || '', '.config', 'TerMinal')
  mkdirSync(cfg, { recursive: true })
  const file = join(cfg, 'hitl.json')
  let list = []
  try {
    if (existsSync(file)) {
      const arr = JSON.parse(readFileSync(file, 'utf8'))
      if (Array.isArray(arr)) list = arr
    }
  } catch {}
  const item = {
    id: randomUUID(),
    title,
    action,
    detail,
    repo,
    source,
    status: 'open',
    createdAt: Date.now(),
    runId,
    ticketPath,
  }
  writeFileSync(file, JSON.stringify([item, ...list], null, 2))
  emitActivityRaw({ kind: 'blocked', title: `HITL · ${title}`, detail: action || detail || '', repo, hitlId: item.id, runId })
  // Telegram ping (best-effort, with inline buttons)
  try {
    const settings = JSON.parse(readFileSync(join(cfg, 'settings.json'), 'utf8'))?.telegram
    if (settings?.botToken && settings?.chatId) {
      const row = [{ text: '✅ Resolve', callback_data: `hitl:resolve:${item.id}` }]
      if (runId) row.push({ text: '🪵 Tail run', callback_data: `run:tail:${runId}` })
      fetch(`https://api.telegram.org/bot${settings.botToken}/sendMessage`, {
        method: 'POST',
        headers: { 'content-type': 'application/json' },
        body: JSON.stringify({
          chat_id: settings.chatId,
          text: `⛔ HITL · ${title}${action ? ` — ${action}` : ''}`,
          reply_markup: { inline_keyboard: [row] },
        }),
        signal: AbortSignal.timeout(8000),
      }).catch(() => {})
    }
  } catch {}
  return { id: item.id }
}

// --- resolve_hitl ---------------------------------------------------------

function resolveHitlTool(args) {
  const { id, resolved = true } = args
  if (!id) throw new Error('id is required')
  const file = join(process.env.HOME || '', '.config', 'TerMinal', 'hitl.json')
  let list = []
  try {
    list = JSON.parse(readFileSync(file, 'utf8'))
  } catch {
    return { ok: false }
  }
  const idx = list.findIndex((h) => h.id === id)
  if (idx < 0) return { ok: false }
  list[idx] = {
    ...list[idx],
    status: resolved ? 'resolved' : 'open',
    resolvedAt: resolved ? Date.now() : undefined,
  }
  writeFileSync(file, JSON.stringify(list, null, 2))
  return { ok: true }
}

// --- emit_activity --------------------------------------------------------

function emitActivityRaw({ kind, title, detail, repo, repoRoot, hitlId, runId }) {
  const cfg = join(process.env.HOME || '', '.config', 'TerMinal')
  mkdirSync(cfg, { recursive: true })
  const file = join(cfg, 'activity.jsonl')
  const ev = {
    id: randomUUID(),
    ts: Date.now(),
    kind: kind || 'info',
    title: title || '',
    detail: detail || '',
    repo: repo || '',
    repoRoot: repoRoot || '',
    ...(hitlId ? { hitlId } : {}),
    ...(runId ? { runId, runSource: 'agent' } : {}),
  }
  try {
    appendFileSync(file, JSON.stringify(ev) + '\n')
  } catch {}
  return ev
}

function emitActivityTool(args) {
  emitActivityRaw(args)
  return { ok: true }
}

// --- set_agent_state / get_agent_state -----------------------------------

function stateFilePath(repoArg, agentId) {
  if (!repoArg) throw new Error('repo is required')
  if (!agentId) throw new Error('agent is required')
  const root = findRepoRoot(repoArg)
  const slug = root ? basename(root) : repoArg
  return join(process.env.HOME || '', '.config', 'TerMinal', 'agent-state', slug, `${agentId}.json`)
}

function setAgentStateTool(args) {
  const { repo, agent, key, value } = args
  if (!key) throw new Error('key is required')
  const file = stateFilePath(repo, agent)
  mkdirSync(dirname(file), { recursive: true })
  let state = {}
  try {
    if (existsSync(file)) state = JSON.parse(readFileSync(file, 'utf8'))
  } catch {}
  state[key] = value
  state.lastRunAt = Date.now()
  writeFileSync(file, JSON.stringify(state, null, 2) + '\n')
  return { ok: true }
}

function getAgentStateTool(args) {
  const { repo, agent, key } = args
  const file = stateFilePath(repo, agent)
  if (!existsSync(file)) return key ? { value: null } : { state: {} }
  try {
    const s = JSON.parse(readFileSync(file, 'utf8'))
    return key ? { value: s[key] ?? null } : { state: s }
  } catch {
    return key ? { value: null } : { state: {} }
  }
}

// ---------------------------------------------------------------------------
// MCP JSON-RPC server (stdio)
//
// We implement the minimal MCP slice: tools/list + tools/call + initialize.
// No prompts, no resources, no completion. Reads stdin line-buffered.
// ---------------------------------------------------------------------------

