#!/usr/bin/env bash
# release — full rebuild of the macOS app + reinstall to /Applications.
#
# Packages (electron-vite build + electron-builder), deep ad-hoc signs (so it
# launches on Apple Silicon), quits the running copy, installs to /Applications,
# and relaunches. This is the "full re-build" flow — run it after changes so the
# installed app is current. (True self-update via electron-updater needs an Apple
# Developer ID signature + notarization; see docs/runbooks/build-and-release.md.)
set -euo pipefail

ROOT="$(cd "$(dirname "$0")/.." && pwd)"
cd "$ROOT"
APP="dist/mac-arm64/TerMinal.app"
DEST="/Applications/TerMinal.app"

echo "▸ building…"
bun run dist

echo "▸ ad-hoc signing…"
codesign --force --deep --sign - "$APP"
codesign --verify --deep --strict "$APP"

echo "▸ installing → /Applications…"
pkill -f "/Applications/TerMinal.app/Contents/MacOS" 2>/dev/null || true
sleep 1
rm -rf "$DEST"
cp -R "$APP" "$DEST"
xattr -cr "$DEST"

echo "▸ launching…"
open "$DEST"
echo "✓ released → $DEST"
