{
  "name": "gauntlet-terminal",
  "version": "0.1.0",
  "description": "An alt-terminal for Claude Code: hosts the real CLI with a pluggable copilot sidebar.",
  "author": "Trevor Miller",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trevormil/gauntlet-terminal.git"
  },
  "homepage": "https://github.com/trevormil/gauntlet-terminal#readme",
  "bugs": "https://github.com/trevormil/gauntlet-terminal/issues",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "dist": "electron-vite build && electron-builder --mac",
    "release": "bin/release",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "rebuild": "electron-rebuild -f -w node-pty",
    "postinstall": "electron-rebuild -f -w node-pty"
  },
  "dependencies": {
    "@codemirror/theme-one-dark": "6.1.3",
    "@fontsource/ibm-plex-mono": "5.2.7",
    "@fontsource/ibm-plex-sans": "5.2.8",
    "@uiw/codemirror-extensions-langs": "4.25.9",
    "@uiw/react-codemirror": "4.25.9",
    "@xterm/addon-web-links": "0.11.0",
    "highlight.js": "11.11.1",
    "lucide-react": "1.16.0",
    "node-pty": "1.0.0",
    "parse-diff": "0.12.0",
    "react-markdown": "10.1.0",
    "remark-gfm": "4.0.1"
  },
  "devDependencies": {
    "@electron/rebuild": "3.7.1",
    "@tailwindcss/vite": "4.1.18",
    "@types/bun": "1.3.14",
    "@types/node": "22.10.5",
    "@types/react": "19.0.2",
    "@types/react-dom": "19.0.2",
    "@vitejs/plugin-react": "4.3.4",
    "@xterm/addon-fit": "0.10.0",
    "@xterm/xterm": "5.5.0",
    "electron": "33.2.1",
    "electron-builder": "26.11.1",
    "electron-vite": "2.3.0",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "tailwindcss": "4.1.18",
    "typescript": "5.7.2",
    "vite": "6.0.7"
  },
  "overrides": {
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.43.0"
  }
}
